# Runtime images (set by deploy workflow)
API_IMAGE=ghcr.io/<owner>/hoop-api:main
WEB_IMAGE=ghcr.io/<owner>/hoop-web:main

# Database (direct internal Postgres on shared Docker network)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hoop
DB_USER=hoop_app
DB_PASSWORD=<strong-password>

# API runtime
JWT_SECRET=replace-me
CORS_ORIGIN=https://hoop.nyhasinavalona.com
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3

# Web runtime
API_URL=http://hoop-api:3001/api
NEXT_PUBLIC_API_URL=https://hoop.nyhasinavalona.com/api
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=https://hoop.nyhasinavalona.com
