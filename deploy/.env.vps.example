# Runtime images (set by deploy workflow)
API_IMAGE=ghcr.io/<owner>/hoop-api:main
WEB_IMAGE=ghcr.io/<owner>/hoop-web:main

# Database (direct internal Postgres on shared Docker network)
DATABASE_URL=postgresql://hoop_app:<strong-password>@postgres:5432/hoop

# API runtime
JWT_SECRET=replace-me
CORS_ORIGIN=https://app.example.com
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3

# Web runtime
API_URL=https://api.example.com/api
NEXT_PUBLIC_API_URL=https://api.example.com/api
NEXTAUTH_SECRET=replace-me
NEXTAUTH_URL=https://app.example.com
